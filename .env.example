# Development — matches `docker-compose.yml` (`database` service maps host port **5433**).
DATABASE_URL="postgresql://jobportal:jobportal@localhost:5433/jobportal?schema=public"

# Optional second database on the same server for tests, after: `createdb -h localhost -p 5433 -U jobportal jobportal_test`
# DATABASE_URL_TEST="postgresql://jobportal:jobportal@localhost:5433/jobportal_test?schema=public"
