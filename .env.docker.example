# Copy to .env for docker compose variable substitution:
#   cp .env.docker.example .env

# Image tag applied to all built services
IMAGE_TAG=latest

# --- Database (service: database) ---
POSTGRES_USER=jobportal
POSTGRES_PASSWORD=jobportal
POSTGRES_DB=jobportal
DATABASE_HOST_PORT=5433

# Backend connection string (hostname must match compose service name: database)
DATABASE_URL=postgresql://jobportal:jobportal@database:5432/jobportal?schema=public

# --- Backend (service: backend) ---
BACKEND_PORT=3000
BACKEND_HOST_PORT=8080
NODE_ENV=production
CORS_ORIGIN=http://localhost:3000

# --- Frontend (service: frontend) ---
FRONTEND_HOST_PORT=3000
VITE_API_BASE_URL=http://localhost:8080
VITE_APP_TITLE=Job Portal
