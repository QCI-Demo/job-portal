{
  "name": "job-portal",
  "version": "0.1.0",
  "private": true,
  "description": "Job Portal — database migrations and Prisma client",
  "scripts": {
    "prisma:generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:seed:validate": "node scripts/validate_seed.js",
    "db:reset": "prisma migrate reset --force",
    "test:migrate": "dotenv -e .env.test -- prisma migrate deploy",
    "test:seed": "dotenv -e .env.test -- sh -c 'prisma migrate deploy && node prisma/seed.js && node scripts/validate_seed.js'"
  },
  "engines": {
    "node": ">=18.18"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.8.2"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
